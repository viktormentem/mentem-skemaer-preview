 }
+// ── Oplæsnings-venlig tilstand: state + toggle ─────────────────────────────
+// Persisteres i localStorage (non-PII UI-præference) → overlever reload + dag-
+// til-dag. G2: et &a11y=1-link vinder ved FØRSTE load; derefter patientens egen
+// toggle. Gælder hele siden (chrome); ét-spørgsmål-flowet rammer dagbogs-formularen.
+const A11Y_KEY = 'mentem_a11y_mode';
+function a11yOn() { try { return localStorage.getItem(A11Y_KEY) === '1'; } catch (e) { return false; } }
+function setA11y(on) { try { localStorage.setItem(A11Y_KEY, on ? '1' : '0'); } catch (e) {} }
+function updateA11yToggleBtn() {
+  const btn = document.getElementById('a11y-mode-btn');
+  if (!btn) return;
+  const on = a11yOn();
+  btn.setAttribute('aria-pressed', on ? 'true' : 'false');
+  btn.textContent = on ? 'Oplæsnings-venlig visning: til' : 'Oplæsnings-venlig visning: fra';
+}
+function onA11yToggle() {
+  const on = !a11yOn();
+  setA11y(on);
+  document.documentElement.setAttribute('data-a11y', on ? '1' : '0');
+  updateA11yToggleBtn();
+  // Re-layout den aktive dagbogs-formular hvis den er åben (ellers virker det v. næste trin-skift).
+  const diaryForm = document.getElementById('screen-diary-form');
+  if (diaryForm && diaryForm.classList.contains('active')) {
+    teardownDiaryStepper();
+    if (on) { diaryStepIndex = 0; applyDiaryStepper(); }
+  }
+}
+function initA11yMode() {
+  let stored = null;
+  try { stored = localStorage.getItem(A11Y_KEY); } catch (e) {}
+  // G2-A: &a11y=1 slår til ved FØRSTE load — kun hvis klienten ikke selv har valgt
+  // endnu (stored === null). Derefter respekteres patientens egen toggle (stored '0'/'1').
+  if (params.get('a11y') === '1' && stored === null) { stored = '1'; setA11y(true); }
+  document.documentElement.setAttribute('data-a11y', stored === '1' ? '1' : '0');
+  const btn = document.getElementById('a11y-mode-btn');
+  if (btn) btn.addEventListener('click', onA11yToggle);
+  updateA11yToggleBtn();
+}
 initTextsize();
 initAloud();
+initA11yMode();
