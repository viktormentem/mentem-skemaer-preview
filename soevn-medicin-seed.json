+// ── Oplæsnings-venlig stepper (synshandicap / skærmlæser) ──────────────────
+// Hvert top-niveau-felt i #diary-fields er ÉT trin. Trinene skjules/vises ét ad
+// gangen; data-bindingen (diaryDraft) er uændret, så svar bevares på tværs af
+// Næste/Forrige. "Spørgsmål X af Y" læses FØRST (fokuseres + aria-live), fokus
+// flyttes til trinnets overskrift, aktivt trin bærer aria-current="step".
+function teardownDiaryStepper() {
+  document.querySelectorAll('.a11y-step-head, .a11y-stepnav').forEach(el => el.remove());
+  document.querySelectorAll('#diary-fields > *').forEach(el => { el.hidden = false; el.removeAttribute('aria-current'); });
+  const save = document.getElementById('diary-save-btn'); if (save) save.style.display = '';
+}
+
+function applyDiaryStepper() {
+  const root = document.getElementById('diary-fields');
+  if (!root || !root.children.length) return;
+  const head = document.createElement('h2');
+  head.id = 'a11y-step-head'; head.className = 'a11y-step-head';
+  head.tabIndex = -1;
+  head.setAttribute('role', 'status');
+  head.setAttribute('aria-live', 'polite');
+  head.setAttribute('aria-atomic', 'true');
+  root.parentNode.insertBefore(head, root);
+
+  const nav = document.createElement('div');
+  nav.className = 'a11y-stepnav';
+  const prev = document.createElement('button');
+  prev.type = 'button'; prev.className = 'btn-secondary'; prev.id = 'a11y-prev'; prev.textContent = 'Forrige';
+  prev.addEventListener('click', () => showDiaryStep(diaryStepIndex - 1));
+  const next = document.createElement('button');
+  next.type = 'button'; next.className = 'btn-primary'; next.id = 'a11y-next'; next.textContent = 'Næste';
+  next.addEventListener('click', () => showDiaryStep(diaryStepIndex + 1));
+  nav.appendChild(prev); nav.appendChild(next);
+  root.parentNode.insertBefore(nav, root.nextSibling);
+
+  showDiaryStep(Math.min(diaryStepIndex, root.children.length - 1), false);
+}
+
+function showDiaryStep(i, moveFocus = true) {
+  const root = document.getElementById('diary-fields');
+  if (!root) return;
+  const steps = Array.from(root.children);
+  if (!steps.length) return;
+  i = Math.max(0, Math.min(i, steps.length - 1));
+  diaryStepIndex = i;
+  steps.forEach((s, idx) => {
+    const on = idx === i;
+    s.hidden = !on;
+    if (on) s.setAttribute('aria-current', 'step'); else s.removeAttribute('aria-current');
+  });
+  const last = i === steps.length - 1;
+  const head = document.getElementById('a11y-step-head');
+  if (head) head.textContent = `Spørgsmål ${i + 1} af ${steps.length}`;
+  const prev = document.getElementById('a11y-prev');
+  const next = document.getElementById('a11y-next');
+  const save = document.getElementById('diary-save-btn');
+  if (prev) prev.disabled = i === 0;
+  if (next) next.style.display = last ? 'none' : '';
+  if (save) save.style.display = last ? '' : 'none';
+  window.scrollTo(0, 0);
+  // Fokus til "Spørgsmål X af Y" → skærmlæser læser fremskridtet FØRST, derefter
+  // navigerer brugeren til selve spørgsmålet. rAF: efter layout/visibility-skift.
+  if (moveFocus && head) requestAnimationFrame(() => { try { head.focus(); } catch (e) {} });
+}
+
 function saveDiaryEntry() {
   const req = diarySkema.fields.filter(f => !f.optional);
   if (req.some(f => { const v = diaryDraft[f.key]; return v == null || v === ''; })) return;
